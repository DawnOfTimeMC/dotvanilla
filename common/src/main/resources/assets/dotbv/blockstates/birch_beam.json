{
	"multipart": [
		{
			"when": { "axis_y": "true" },
			"apply": { "model": "dotbv:block/birch_beam_y"}
		},
		{
			"when": {"axis_x": "true", "axis_z": "false" },
			"apply": { "model": "dotbv:block/birch_beam_x"}
		},
		{
			"when": {"axis_x": "false", "axis_z": "true" },
			"apply": { "model": "dotbv:block/birch_beam_x", "y": 90}
		},
		{
			"when": {"axis_x": "true", "axis_z": "true" },
			"apply": { "model": "dotbv:block/birch_beam_x_z"}
		},
		{
			"when": { "bottom": "true" },
			"apply": { "model": "dotbv:block/birch_beam_bottom"}
		}
	]
}